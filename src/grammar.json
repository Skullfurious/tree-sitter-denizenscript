{
  "$schema": "https://tree-sitter.github.io/tree-sitter/assets/schemas/grammar.schema.json",
  "name": "denizenscript",
  "rules": {
    "source_file": {
      "type": "REPEAT",
      "content": {
        "type": "SYMBOL",
        "name": "_definition"
      }
    },
    "comment": {
      "type": "TOKEN",
      "content": {
        "type": "SEQ",
        "members": [
          {
            "type": "STRING",
            "value": "#"
          },
          {
            "type": "PATTERN",
            "value": ".*"
          }
        ]
      }
    },
    "_identifier": {
      "type": "PATTERN",
      "value": "[a-zA-Z0-9_]+"
    },
    "_definition": {
      "type": "CHOICE",
      "members": [
        {
          "type": "SYMBOL",
          "name": "script_container_block"
        }
      ]
    },
    "script_container_block": {
      "type": "SEQ",
      "members": [
        {
          "type": "SYMBOL",
          "name": "script_name"
        },
        {
          "type": "SYMBOL",
          "name": "_indent"
        },
        {
          "type": "REPEAT1",
          "content": {
            "type": "CHOICE",
            "members": [
              {
                "type": "SYMBOL",
                "name": "key_value_block"
              },
              {
                "type": "SYMBOL",
                "name": "key_list_block"
              },
              {
                "type": "SYMBOL",
                "name": "key_map_block"
              }
            ]
          }
        },
        {
          "type": "SYMBOL",
          "name": "_dedent"
        }
      ]
    },
    "key_value_block": {
      "type": "PREC",
      "value": 1,
      "content": {
        "type": "SEQ",
        "members": [
          {
            "type": "SYMBOL",
            "name": "key_component"
          },
          {
            "type": "SYMBOL",
            "name": "value_component"
          },
          {
            "type": "SYMBOL",
            "name": "_newline"
          }
        ]
      }
    },
    "key_list_block": {
      "type": "SEQ",
      "members": [
        {
          "type": "SYMBOL",
          "name": "key_component"
        },
        {
          "type": "SYMBOL",
          "name": "_newline"
        },
        {
          "type": "SYMBOL",
          "name": "_indent"
        },
        {
          "type": "REPEAT1",
          "content": {
            "type": "SYMBOL",
            "name": "list_item"
          }
        },
        {
          "type": "SYMBOL",
          "name": "_dedent"
        }
      ]
    },
    "key_map_block": {
      "type": "SEQ",
      "members": [
        {
          "type": "SYMBOL",
          "name": "key_component"
        },
        {
          "type": "SYMBOL",
          "name": "_newline"
        },
        {
          "type": "SYMBOL",
          "name": "_indent"
        },
        {
          "type": "REPEAT1",
          "content": {
            "type": "SYMBOL",
            "name": "key_value_block"
          }
        },
        {
          "type": "SYMBOL",
          "name": "_dedent"
        }
      ]
    },
    "script_name": {
      "type": "SEQ",
      "members": [
        {
          "type": "SYMBOL",
          "name": "_identifier"
        },
        {
          "type": "STRING",
          "value": ":"
        },
        {
          "type": "SYMBOL",
          "name": "_newline"
        }
      ]
    },
    "key_component": {
      "type": "SEQ",
      "members": [
        {
          "type": "SYMBOL",
          "name": "_identifier"
        },
        {
          "type": "STRING",
          "value": ":"
        }
      ]
    },
    "value_component": {
      "type": "PATTERN",
      "value": "[^\\n]+"
    },
    "list_item": {
      "type": "SEQ",
      "members": [
        {
          "type": "STRING",
          "value": "-"
        },
        {
          "type": "SYMBOL",
          "name": "command_body"
        },
        {
          "type": "SYMBOL",
          "name": "_newline"
        }
      ]
    },
    "command_body": {
      "type": "PATTERN",
      "value": "[^\\n]+"
    },
    "tag_component": {
      "type": "SEQ",
      "members": [
        {
          "type": "STRING",
          "value": "<"
        },
        {
          "type": "SYMBOL",
          "name": "tag_content"
        },
        {
          "type": "STRING",
          "value": ">"
        }
      ]
    },
    "tag_content": {
      "type": "SEQ",
      "members": [
        {
          "type": "SYMBOL",
          "name": "_tag_matcher"
        },
        {
          "type": "CHOICE",
          "members": [
            {
              "type": "SYMBOL",
              "name": "tag_object"
            },
            {
              "type": "BLANK"
            }
          ]
        }
      ]
    },
    "_tag_matcher": {
      "type": "PATTERN",
      "value": "[a-zA-Z0-9_.]+"
    },
    "tag_object": {
      "type": "SEQ",
      "members": [
        {
          "type": "STRING",
          "value": "["
        },
        {
          "type": "CHOICE",
          "members": [
            {
              "type": "SYMBOL",
              "name": "_tag_matcher"
            },
            {
              "type": "SYMBOL",
              "name": "tag_component"
            }
          ]
        },
        {
          "type": "STRING",
          "value": "]"
        }
      ]
    }
  },
  "extras": [
    {
      "type": "SYMBOL",
      "name": "comment"
    },
    {
      "type": "PATTERN",
      "value": "[\\s\\f\\uFEFF\\u2060\\u200B]"
    }
  ],
  "conflicts": [],
  "precedences": [],
  "externals": [
    {
      "type": "SYMBOL",
      "name": "_newline"
    },
    {
      "type": "SYMBOL",
      "name": "_indent"
    },
    {
      "type": "SYMBOL",
      "name": "_dedent"
    },
    {
      "type": "SYMBOL",
      "name": "string_start"
    },
    {
      "type": "SYMBOL",
      "name": "_string_content"
    },
    {
      "type": "SYMBOL",
      "name": "escape_interpolation"
    },
    {
      "type": "SYMBOL",
      "name": "string_end"
    },
    {
      "type": "SYMBOL",
      "name": "comment"
    },
    {
      "type": "STRING",
      "value": "]"
    },
    {
      "type": "STRING",
      "value": ")"
    },
    {
      "type": "STRING",
      "value": "}"
    },
    {
      "type": "STRING",
      "value": "except"
    }
  ],
  "inline": [],
  "supertypes": [],
  "reserved": {}
}